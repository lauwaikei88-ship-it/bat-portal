# Bat Portal Environment Variables
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to GitHub

# ── Supabase ──────────────────────────────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Agnes AI ──────────────────────────────────────────────────────
# Your existing Agnes API key
AGNES_API_KEY=sk-lFGQZpj2KA2GqrUqXlN65qHD6u4aTLPFX9mlnpZTSOIMs7NS

# ── Instagram / Meta ──────────────────────────────────────────────
# Your long-lived token (valid 60 days, needs renewal)
META_ACCESS_TOKEN=your_long_lived_meta_token
IG_ACCOUNT_ID=17841426621372364

# ── Vercel Cron Security ──────────────────────────────────────────
# Generate any random secret string. Must match Vercel env var.
CRON_SECRET=bat_portal_cron_secret_change_this
